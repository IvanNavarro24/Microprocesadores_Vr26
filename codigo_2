#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#include <xc.h>
#include "lcd.h"

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 8000000

//==================================================
// ADC
//==================================================

void ADC_Init()
{
    ANSEL = 0x01;      // RA0 analógico
    ANSELH = 0x00;     // Resto digital

    ADCON0 = 0x81;     // ADC ON, canal AN0
    ADCON1 = 0x80;     // Justificado a la derecha
}

unsigned int ADC_Read()
{
    __delay_us(10);

    GO_nDONE = 1;
    while(GO_nDONE);

    return ((ADRESH << 8) | ADRESL);
}

//==================================================
// MAIN
//==================================================

void main(void)
{
    ADC_Init();

    // RB0 como entrada
    TRISBbits.TRISB0 = 1;

    // Pull-up interna en RB0
    OPTION_REGbits.nRBPU = 0;
    WPUBbits.WPUB0 = 1;

    LCD lcd = {&PORTC,2,3,4,5,6,7};
    LCD_Init(lcd);

    char buffer[16];

    unsigned char modo = 0;

    while(1)
    {
        unsigned int adc_result = ADC_Read();

        //==================================================
        // DETECCIÓN DE BOTÓN
        //==================================================

        if(PORTBbits.RB0 == 0) // pulsado
        {
            __delay_ms(30);

            if(PORTBbits.RB0 == 0)
            {
                modo++;

                if(modo > 2)
                    modo = 0;

                LCD_Clear();

                while(PORTBbits.RB0 == 0);
                __delay_ms(30);
            }
        }

        //==================================================
        // MODO VOLTAJE
        //==================================================

        if(modo == 0)
        {
            LCD_Set_Cursor(0,0);
            LCD_putrs("Voltaje:");

            unsigned long mV =
                ((unsigned long)adc_result * 5000UL) / 1023UL;

            unsigned int entero = mV / 1000;
            unsigned int decimal = mV % 1000;

            sprintf(buffer,"%u.%03u V",entero,decimal);

            LCD_Set_Cursor(1,0);
            LCD_putrs("                ");
            LCD_Set_Cursor(1,0);
            LCD_putrs(buffer);
        }

        //==================================================
        // MODO ADC
        //==================================================

        else if(modo == 1)
        {
            LCD_Set_Cursor(0,0);
            LCD_putrs("ADC:");

            sprintf(buffer,"%u",adc_result);

            LCD_Set_Cursor(1,0);
            LCD_putrs("                ");
            LCD_Set_Cursor(1,0);
            LCD_putrs(buffer);
        }

        //==================================================
        // MODO PORCENTAJE
        //==================================================

        else if(modo == 2)
        {
            LCD_Set_Cursor(0,0);
            LCD_putrs("Porcentaje:");

            unsigned int porcentaje =
                ((unsigned long)adc_result * 100UL) / 1023UL;

            sprintf(buffer,"%u %%",porcentaje);

            LCD_Set_Cursor(1,0);
            LCD_putrs("                ");
            LCD_Set_Cursor(1,0);
            LCD_putrs(buffer);
        }

        __delay_ms(100);
    }
}
