#include <xc.h>
#include <stdbool.h>
#include "lcd.h"

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 8000000

void LCD_CreateChar(unsigned char location, unsigned char charmap[])
{
    unsigned char i;

    location &= 0x07;

    LCD_Cmd(0x40 + (location * 8));

    for(i = 0; i < 8; i++)
    {
        LCD_putc(charmap[i]);
    }
}

// Carita feliz
unsigned char feliz[8] =
{
    0b00000,
    0b01010,
    0b01010,
    0b00000,
    0b10001,
    0b01110,
    0b00000,
    0b00000
};

// Gato
unsigned char gato[8] =
{
    0b10001,
    0b11011,
    0b11111,
    0b10101,
    0b11111,
    0b01110,
    0b01010,
    0b00000
};

void main(void)
{
    LCD lcd = {&PORTC,2,3,4,5,6,7};

    ANSEL = 0;
    ANSELH = 0;

    TRISBbits.TRISB0 = 1;   // Bot�n

    OPTION_REGbits.nRBPU = 0; // Habilita pull-ups
    WPUBbits.WPUB0 = 1;       // Pull-up en RB0

    LCD_Init(lcd);

    LCD_CreateChar(0, feliz);
    LCD_CreateChar(1, gato);

    unsigned char caracter = 0;
    unsigned char estadoAnterior = 1;

    LCD_Clear();

    LCD_Set_Cursor(0,0);
    LCD_putrs("Caracter:");

    while(1)
    {
        LCD_Set_Cursor(1,7);
        LCD_putc(caracter);

        if(estadoAnterior == 1 && PORTBbits.RB0 == 0)
        {
            caracter++;

            if(caracter > 1)
            {
                caracter = 0;
            }

            LCD_Set_Cursor(1,7);
            LCD_putc(caracter);

            __delay_ms(200); // Anti-rebote
        }

        estadoAnterior = PORTBbits.RB0;
    }
}
