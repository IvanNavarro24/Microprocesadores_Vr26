#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#include <xc.h>
#include "lcd.h"

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 8000000

volatile unsigned int tiempo = 0;
volatile unsigned char contador = 0;

char exec[10];
char voltStr[16];

void Timer1_Init(void)
{
    T1CON = 0b00110001;
    // Prescaler 1:8
    // Clock interno (Fosc/4)
    // Timer1 encendido

    TMR1H = 0x9E;
    TMR1L = 0x58;

    TMR1IF = 0;
    TMR1IE = 1;

    PEIE = 1;
    GIE = 1;
}

void __interrupt() ISR(void)
{
    if(TMR1IF)
    {
        TMR1H = 0x9E;
        TMR1L = 0x58;

        contador++;

        if(contador >= 10)
        {
            tiempo++;
            contador = 0;
        }

        TMR1IF = 0;
    }
}

void main(void)
{
    Timer1_Init();

    // Configurar ADC en AN0
    TRISA  = 0xFF;
    ANSEL  = 0x01;
    ADCON0 = 0x41;
    ADCON1 = 0x80;

    LCD lcd = {&PORTC, 2, 3, 4, 5, 6, 7};

    LCD_Init(lcd);
    LCD_Clear();

    LCD_Set_Cursor(0, 0);
    LCD_putrs("Volt:");

    while(1)
    {
        // Leer ADC
        ADCON0bits.GO = 1;
        while(ADCON0bits.GO);

        unsigned int adcVal = ((unsigned int)ADRESH << 8) | ADRESL;

        unsigned int mv =
            (unsigned int)((unsigned long)adcVal * 500UL / 1023UL);

        unsigned int entero  = mv / 100;
        unsigned int decimal = mv % 100;

        // Mostrar voltaje
        LCD_Set_Cursor(0, 5);
        sprintf(voltStr, " %u.%02uV", entero, decimal);
        LCD_putrs(voltStr);

        // Mostrar reloj MM:SS
        sprintf(exec, "%02u:%02u", tiempo / 60, tiempo % 60);

        LCD_Set_Cursor(1, 11);
        LCD_putrs(exec);

        __delay_ms(100);
    }
}
