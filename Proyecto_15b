#include <xc.h>

#define _XTAL_FREQ 8000000

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

void UART_Init(void)
{
    TRISCbits.TRISC7 = 1;     // RX

    SPBRG = 12;               // 9600 baud @ 8MHz
    BRGH = 1;

    SYNC = 0;
    SPEN = 1;
    CREN = 1;
}

char UART_Read(void)
{
    while(!RCIF);

    if(OERR)
    {
        CREN = 0;
        CREN = 1;
    }

    return RCREG;
}

void main(void)
{
    char dato;

    ANSEL = 0;
    ANSELH = 0;

    UART_Init();

    TRISCbits.TRISC0 = 0;
    PORTCbits.RC0 = 0;

    while(1)
    {
        dato = UART_Read();

        if(dato == '1')
        {
            PORTCbits.RC0 = 1;
        }
        else if(dato == '0')
        {
            PORTCbits.RC0 = 0;
        }
    }
}
