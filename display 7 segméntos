#include <xc.h>

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 8000000

// Códigos para display de 7 segmentos cátodo común
unsigned char numeros[10] = {
    0x3F,   // 0
    0x06,   // 1
    0x5B,   // 2
    0x4F,   // 3
    0x66,   // 4
    0x6D,   // 5
    0x7D,   // 6
    0x07,   // 7
    0x7F,   // 8
    0x6F    // 9
};

void main(void)
{
    unsigned char i;

    TRISD = 0x00;   // PORTD como salida
    PORTD = 0x00;

    while(1)
    {
        for(i = 0; i < 10; i++)
        {
            PORTD = numeros[i];
            __delay_ms(1000);   // 1 segundo
        }
    }
}
