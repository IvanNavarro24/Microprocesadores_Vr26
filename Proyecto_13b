#include <xc.h>

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 8000000

//================================================
// ADC
//================================================

void ADC_Init(void)
{
    ANSEL = 0x01;
    ANSELH = 0x00;

    ADCON0 = 0x01;
    ADCON1 = 0x80;
}

unsigned int ADC_Read(unsigned char canal)
{
    ADCON0 &= 0b11000011;
    ADCON0 |= (canal << 2);

    __delay_us(20);

    GO_nDONE = 1;
    while(GO_nDONE);

    return (((unsigned int)ADRESH << 8) | ADRESL);
}

//================================================
// PWM CCP1
//================================================

void PWM1_Init(void)
{
    TRISCbits.TRISC2 = 0;

    PR2 = 124;

    CCP1CON = 0b00001100;

    T2CON = 0b00000101;
}

void PWM1_SetDuty(unsigned int duty)
{
    unsigned int pwm;

    pwm = ((unsigned long)duty * 499UL) / 1023UL;

    CCPR1L = pwm >> 2;

    CCP1CONbits.DC1B1 = (pwm >> 1) & 1;
    CCP1CONbits.DC1B0 = pwm & 1;
}

//================================================
// MAIN
//================================================

void main(void)
{
    unsigned int velocidad;
    unsigned char direccion = 0; // 0=paro, 1=izquierda, 2=derecha

    ADC_Init();
    PWM1_Init();

    TRISBbits.TRISB0 = 1;
    TRISBbits.TRISB1 = 1;

    TRISDbits.TRISD0 = 0;
    TRISDbits.TRISD1 = 0;

    RD0 = 0;
    RD1 = 0;

    while(1)
    {
        velocidad = ADC_Read(0);
        PWM1_SetDuty(velocidad);

        // Botón izquierda
        if(RB0 == 1)
        {
            direccion = 1;

            while(RB0 == 1);   // Esperar a soltar
            __delay_ms(20);    // Antirrebote
        }

        // Botón derecha
        if(RB1 == 1)
        {
            direccion = 2;

            while(RB1 == 1);   // Esperar a soltar
            __delay_ms(20);    // Antirrebote
        }

        // Aplicar dirección guardada
        switch(direccion)
        {
            case 1: // Izquierda
                RD0 = 1;
                RD1 = 0;
                break;

            case 2: // Derecha
                RD0 = 0;
                RD1 = 1;
                break;

            default: // Paro
                RD0 = 0;
                RD1 = 0;
                break;
        }
    }
}
