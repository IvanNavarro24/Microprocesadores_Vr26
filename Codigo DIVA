// Invierte el orden de los bits (espejo horizontal)
unsigned char invertirBits(unsigned char dato) {
    dato = ((dato & 0xF0) >> 4) | ((dato & 0x0F) << 4);
    dato = ((dato & 0xCC) >> 2) | ((dato & 0x33) << 2);
    dato = ((dato & 0xAA) >> 1) | ((dato & 0x55) << 1);
    return dato;
}

void mostrarPatron(unsigned char *patron, unsigned int rep) {
    unsigned int r;
    unsigned char i;

    for (r = 0; r < rep; r++) {
        for (i = 0; i < 8; i++) {

            PORTB = (1 << i);                // Activar fila
            PORTD = ~invertirBits(patron[i]); // Mostrar columnas

            __delay_ms(5);
        }
    }
}

void main(void) {

    TRISB = 0x00;   // Filas
    TRISD = 0x00;   // Columnas

    PORTB = 0x00;
    PORTD = 0xFF;

    while(1) {

        mostrarPatron(letraD, 60);
        mostrarPatron(letraI, 60);
        mostrarPatron(letraV, 60);
        mostrarPatron(letraA, 60);
    }
}
